APP_NAME=events-aggregator
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@POSTGRES_SERVICE_NAME:5432/DB_NAME

EVENTS_PROVIDER_BASE_URL=
EVENTS_PROVIDER_API_KEY=

ENABLE_BACKGROUND_SYNC=true
SYNC_INTERVAL_SECONDS=86400
SEATS_CACHE_TTL_SECONDS=30

# Notification service (Capashino)
CAPASHINO_BASE_URL=
CAPASHINO_API_KEY=

# Transactional Outbox
OUTBOX_POLL_INTERVAL_SECONDS=10
OUTBOX_BATCH_SIZE=100
OUTBOX_SENT_RETENTION_DAYS=7

# Idempotency
IDEMPOTENCY_KEY_TTL_SECONDS=86400

# Observability
GLITCHTIP_DSN=